/**
 * NigWrite Database Schema
 * Academic Integrity & Writing Assistant Platform
 * Created by: Wabi The Tech Nurse
 *
 * Microservices architecture using Next.js + Prisma ORM.
 * This schema models the complete data flow for plagiarism detection,
 * AI content detection, and the plagiarism correction engine.
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Developer Metadata
// Tracks app version and credits the creator
// ──────────────────────────────────────────────
model DeveloperMeta {
  id          String @id @default(cuid())
  appVersion  String @default("1.0.0")
  creatorName String @default("Wabi The Tech Nurse")
  description String @default("NigWrite — Academic Integrity & Writing Assistant Platform")
  updatedAt   DateTime @updatedAt
}

// ──────────────────────────────────────────────
// User Management
// Users belong to institutions (schools, universities)
// ──────────────────────────────────────────────
model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  password      String       // hashed password (bcryptjs)
  role          String       @default("student") // student, lecturer, admin
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  documents     Document[]
  assignments   Assignment[]
  submissions  Submission[]
  notifications Notification[]
  quickMarks       QuickMark[]
  inlineComments   InlineComment[]
  voiceComments    VoiceComment[]
  rubricScores     RubricScore[] @relation("GradedByUser")
  gradedSubmissions Submission[] @relation("Grader")
  sharedReports    ReportShare[]
  sourceDocuments  SourceDocument[]
  enrollments       Enrollment[]
  taughtCourses     Course[]  @relation("InstructorCourses")
  auditLogs         AuditLog[]
  peerReviewsGiven   PeerReview[] @relation("PeerReviewer")
  peerReviewsReceived PeerReview[] @relation("PeerReviewee")
  apiKeys           ApiKey[]
  webhooks          Webhook[]
}

// ──────────────────────────────────────────────
// Institutions (Universities, Schools)
// ──────────────────────────────────────────────
model Institution {
  id          String   @id @default(cuid())
  name        String
  domain      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  assignments Assignment[]
  courses     Course[]
}

// ──────────────────────────────────────────────
// Documents
// Stores the full content body of uploaded papers
// ──────────────────────────────────────────────
model Document {
  id          String       @id @default(cuid())
  title       String
  contentBody String
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  reports      ScanReport[]
  submissions  Submission[]
}

// ──────────────────────────────────────────────
// Scan Reports
// One document can have multiple scan reports
// (original scan + post-correction re-scan)
// ──────────────────────────────────────────────
model ScanReport {
  id              String           @id @default(cuid())
  documentId      String
  document        Document         @relation(fields: [documentId], references: [id])
  similarityScore Float            @default(0) // 0-100 percentage
  aiScore         Float            @default(0) // 0-100 percentage
  status          String           @default("completed") // pending, processing, completed
  createdAt       DateTime         @default(now())
  flaggedSegments FlaggedSegment[]
  submission      Submission?
  shares          ReportShare[]
}

// ──────────────────────────────────────────────
// Flagged Segments
// Individual text passages flagged as plagiarized or AI-generated
// ──────────────────────────────────────────────
model FlaggedSegment {
  id              String     @id @default(cuid())
  reportId        String
  report          ScanReport @relation(fields: [reportId], references: [id])
  segmentText     String     // original flagged text
  sourceLink      String?    // matched source URL (if found)
  similarityType  String     @default("plagiarism") // plagiarism, ai_generated
  suggestedRewrite String?   // AI-generated rewrite suggestion
  rewriteApplied  Boolean    @default(false)
  createdAt       DateTime   @default(now())
}

// ──────────────────────────────────────────────
// Source Documents (Reference Corpus)
// Pre-loaded documents used as the comparison database
// ──────────────────────────────────────────────
model SourceDocument {
  id            String        @id @default(cuid())
  externalId    String        @unique
  title         String
  content       String
  sourceType    String        @default("publication") // "publication", "internet", "student_paper"
  sourceUrl     String?
  discipline    String?
  author        String?
  isUserDocument Boolean       @default(false)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  fingerprints  Fingerprint[]
  addedAt       DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([externalId])
  @@index([isUserDocument])
}

model Fingerprint {
  id          String         @id @default(cuid())
  hashValue   Int
  documentId  String
  document    SourceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  position    Int
  ngram       String

  @@index([hashValue])
  @@index([documentId])
}

// ──────────────────────────────────────────────
// Assignments (Instructor-created tasks)
// ──────────────────────────────────────────────
model Assignment {
  id            String       @id @default(cuid())
  title         String
  description   String
  courseId      String?
  course        Course?       @relation(fields: [courseId], references: [id])
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  createdBy     String
  creator       User         @relation(fields: [createdBy], references: [id])
  deadline      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submissions   Submission[]
  peerReviews   PeerReview[]
  rubrics           Rubric[]
  allowResubmissions Boolean  @default(true)
  maxResubmissions  Int       @default(5)
  allowLateSubmission Boolean  @default(true)
  latePenalty       Float?
  anonymousGrading  Boolean   @default(false)
  gradeScale        String    @default("0-100")
  maxGrade          Float     @default(100)
}

// ──────────────────────────────────────────────
// Submissions (Student submissions to assignments)
// ──────────────────────────────────────────────
model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String?
  student      User?      @relation(fields: [studentId], references: [id])
  documentId   String
  document     Document   @relation(fields: [documentId], references: [id])
  reportId     String?    @unique
  report       ScanReport? @relation(fields: [reportId], references: [id])
  status       String     @default("submitted") // submitted, graded, flagged
  grade        Float?
  gradeScale     String?       @default("0-100")
  letterGrade    String?
  isDraft        Boolean       @default(false)
  version        Int           @default(1)
  parentVersionId String?
  feedbackSummary String?
  feedback       String?
  gradedAt       DateTime?
  gradedBy       String?
  grader         User?         @relation("Grader", fields: [gradedBy], references: [id])
  inlineComments  InlineComment[]
  voiceComments   VoiceComment[]
  rubricScores    RubricScore[]
  peerReviews     PeerReview[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ──────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info") // info, warning, success, error
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Rubrics (Grading criteria templates)
// ──────────────────────────────────────────────
model Rubric {
  id              String        @id @default(cuid())
  title           String
  description     String?
  assignmentId    String?
  assignment      Assignment?   @relation(fields: [assignmentId], references: [id])
  criteria        RubricCriteria[]
  rubricScores    RubricScore[]
  peerReviews     PeerReview[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model RubricCriteria {
  id          String  @id @default(cuid())
  rubricId    String
  rubric      Rubric  @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  title       String
  description String?
  maxScore    Float   @default(10)
  weight      Float   @default(1)
  levels      RubricLevel[]
  rubricScores RubricScore[]
  peerReviewCriteriaScores PeerReviewCriteriaScore[]
  order       Int     @default(0)
}

model RubricLevel {
  id          String  @id @default(cuid())
  criteriaId  String
  criteria    RubricCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  label       String
  description String
  score       Float
  rubricScores RubricScore[]
  order       Int           @default(0)
}

// ──────────────────────────────────────────────
// Inline Comments (on submissions)
// ──────────────────────────────────────────────
model InlineComment {
  id           String      @id @default(cuid())
  submissionId String
  submission   Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  text         String
  position     Int
  rangeLength  Int         @default(0)
  color        String      @default("#FFD700")
  isResolved   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// ──────────────────────────────────────────────
// Quick Marks (Reusable comment templates)
// ──────────────────────────────────────────────
model QuickMark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  text      String
  category  String   @default("General")
  color     String   @default("#FFD700")
  useCount  Int      @default(0)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Voice Comments (Audio feedback on submissions)
// ──────────────────────────────────────────────
model VoiceComment {
  id           String      @id @default(cuid())
  submissionId String
  submission   Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  audioData    String
  duration     Int         @default(0)
  createdAt    DateTime    @default(now())
}

// ──────────────────────────────────────────────
// Rubric Scores (Per-criterion scores)
// ──────────────────────────────────────────────
model RubricScore {
  id             String        @id @default(cuid())
  submissionId   String
  submission     Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  rubricId       String
  rubric         Rubric        @relation(fields: [rubricId], references: [id])
  criteriaId     String
  criteria       RubricCriteria @relation(fields: [criteriaId], references: [id])
  levelId        String?
  level          RubricLevel?  @relation(fields: [levelId], references: [id])
  score          Float
  feedback       String?
  gradedBy       String
  gradedByUser   User          @relation("GradedByUser", fields: [gradedBy], references: [id])
  createdAt      DateTime      @default(now())
}

// ──────────────────────────────────────────────
// Courses
// ──────────────────────────────────────────────
model Course {
  id            String        @id @default(cuid())
  name          String
  code          String
  description   String?
  department    String?
  institutionId String?
  institution   Institution?  @relation(fields: [institutionId], references: [id])
  instructorId  String?
  instructor    User?         @relation("InstructorCourses", fields: [instructorId], references: [id])
  assignments   Assignment[]
  enrollments   Enrollment[]
  startDate     DateTime?
  endDate       DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ──────────────────────────────────────────────
// Enrollments
// ──────────────────────────────────────────────
model Enrollment {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  role       String   @default("student")
  enrolledAt DateTime @default(now())
  @@unique([courseId, userId])
}

// ──────────────────────────────────────────────
// Audit Logs
// ──────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String
  resourceId String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// System Settings
// ──────────────────────────────────────────────
model SystemSettings {
  id                    String   @id @default(cuid())
  key                   String   @unique
  value                 String
  description           String?
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

// ──────────────────────────────────────────────
// Peer Reviews
// PeerMark-style anonymous peer review system
// ──────────────────────────────────────────────
model PeerReview {
  id              String      @id @default(cuid())
  assignmentId    String
  assignment      Assignment  @relation(fields: [assignmentId], references: [id])
  reviewerId      String
  reviewer        User        @relation("PeerReviewer", fields: [reviewerId], references: [id])
  revieweeId      String
  reviewee        User        @relation("PeerReviewee", fields: [revieweeId], references: [id])
  submissionId    String
  submission      Submission  @relation(fields: [submissionId], references: [id])
  status          String      @default("pending") // pending, in_progress, completed
  rubricId        String?
  rubric          Rubric?     @relation(fields: [rubricId], references: [id])
  overallScore    Float?
  overallComment  String?
  criteriaScores  PeerReviewCriteriaScore[]
  isAnonymous     Boolean     @default(true)
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model PeerReviewCriteriaScore {
  id          String      @id @default(cuid())
  reviewId    String
  review      PeerReview  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  criteriaId  String
  criteria    RubricCriteria @relation(fields: [criteriaId], references: [id])
  score       Float
  comment     String?
}

// ──────────────────────────────────────────────
// Report Shares
// Shared links for viewing plagiarism reports
// ──────────────────────────────────────────────
model ReportShare {
  id          String     @id @default(cuid())
  reportId    String
  scanReport  ScanReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  shareToken  String     @unique
  password    String?
  expiresAt   DateTime?
  viewCount   Int        @default(0)
  maxViews    Int?
  createdAt   DateTime   @default(now())
  createdBy   String
  creator     User       @relation(fields: [createdBy], references: [id])
}

// ──────────────────────────────────────────────
// API Keys
// For public API access and integrations
// ──────────────────────────────────────────────
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key         String   @unique
  name        String
  permissions String   @default("scan")
  lastUsed    DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
}

// ──────────────────────────────────────────────
// Webhooks
// For event-driven integrations
// ──────────────────────────────────────────────
model Webhook {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url             String
  events          String    @default("scan.complete")
  secret          String
  isActive        Boolean   @default(true)
  lastTriggered   DateTime?
  createdAt       DateTime  @default(now())
}
