# NigWrite - Environment Variables

# ── Local Development (SQLite) ──
DATABASE_URL=file:./db/custom.db

# ── Vercel / Turso Production (auto-set by Vercel Turso integration) ──
# STORAGE_URL=libsql://your-db.turso.io
# STORAGE_AUTH_TOKEN=your-auth-token

# ── NextAuth (if enabled) ──
# NEXTAUTH_SECRET=your-secret
# NEXTAUTH_URL=http://localhost:3000
